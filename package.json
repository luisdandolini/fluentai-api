{
  "name": "fluentai-api",
  "packageManager": "yarn@4.10.3",
  "type": "module",
  "scripts": {
    "dev": "yarn node --experimental-strip-types --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "migrate": "dotenv -e .env -- prisma migrate dev",
    "migrate:prod": "dotenv -e .env -- prisma migrate deploy",
    "studio": "dotenv -e .env -- prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^7.4.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.1",
    "prisma": "^7.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.24.1"
  }
}

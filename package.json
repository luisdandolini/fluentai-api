{
  "name": "fluentai-api",
  "packageManager": "yarn@4.10.3",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch --ignore './node_modules/**' --ignore './.prisma/**' src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "migrate": "dotenv -e .env -- prisma migrate dev",
    "migrate:prod": "dotenv -e .env -- prisma migrate deploy",
    "studio": "dotenv -e .env -- prisma studio",
    "db:generate": "prisma generate",
    "seed": "dotenv -e .env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "groq-sdk": "^0.37.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "pg": "^8.19.0",
    "resend": "^6.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.18.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.1",
    "prisma": "^7.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.24.1"
  }
}
